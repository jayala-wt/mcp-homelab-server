# MCP Homelab Server — environment configuration
# Copy to .env and adjust for your environment

# Comma-separated list of git repo roots to allow operations on
MCP_REPO_ROOTS=/path/to/your/repo,/path/to/another/repo

# Path to write the audit log (JSONL format)
MCP_AUDIT_LOG_PATH=./logs/mcp_audit.jsonl

# Service management mode: "auto", "systemd", or "docker"
WANATUX_MODE=auto

# Systemd service name to manage (lab_restart, lab_status)
WANATUX_SYSTEMD_SERVICE=your-service-name

# Docker Compose directory and service name (if using Docker mode)
WANATUX_COMPOSE_DIR=
WANATUX_COMPOSE_SERVICE=

# Path to a custom restart shell script (optional)
WANATUX_RESTART_SCRIPT=

# Hostname used in error envelopes
WANATUX_HOST=localhost

# Knowledge DB path (for knowledge_* tools)
KNOWLEDGE_DB_PATH=./data/knowledge.db

# Devloop DB path (for devloop_* tools)
DEVLOOP_DB_PATH=./data/devloop.db
